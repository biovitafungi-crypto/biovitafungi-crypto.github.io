<script>
  // ---------- header scroll state ----------
  const header = document.getElementById('siteHeader');
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  });

  // ---------- reveal on scroll ----------
  const revealEls = document.querySelectorAll('.reveal, .stage');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  revealEls.forEach(el => io.observe(el));

  // ---------- mycelium network canvas ----------
  const canvas = document.getElementById('myceliumCanvas');
  const ctx = canvas.getContext('2d');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let segments = [];
  let W, H;

  function resize(){
    const hero = document.getElementById('inicio');
    W = canvas.width = hero.offsetWidth;
    H = canvas.height = hero.offsetHeight;
  }

  function buildTree(){
    segments = [];
    const roots = 5;
    for(let r=0;r<roots;r++){
      const x0 = (0.08 + r*(0.84/(roots-1))) ;
      const angle0 = -90 + (Math.random()*40-20);
      grow(x0, 1.02, angle0, 0.16 + Math.random()*0.05, 6, 0);
    }
  }

  function grow(x, y, angle, len, depth, order){
    if(depth<=0) return;
    const rad = angle*Math.PI/180;
    const x2 = x + Math.cos(rad)*len;
    const y2 = y + Math.sin(rad)*len;
    segments.push({x1:x,y1:y,x2:x2,y2:y2,order:order,depth:depth});
    const branches = depth>4 ? 2 : (Math.random()>0.35?2:1);
    for(let i=0;i<branches;i++){
      const spread = (Math.random()*46+10) * (i===0?-1:1);
      grow(x2, y2, angle+spread, len*(0.74+Math.random()*0.1), depth-1, order+1);
    }
  }

  buildTree();
  resize();
  window.addEventListener('resize', () => { resize(); });

  let start = null;
  function draw(ts){
    if(!start) start = ts;
    const t = ts - start;
    ctx.clearRect(0,0,W,H);
    segments.forEach(seg => {
      const delay = seg.order*190;
      const dur = 420;
      const progress = reduceMotion ? 1 : Math.max(0, Math.min(1, (t-delay)/dur));
      if(progress<=0) return;
      const ex = seg.x1 + (seg.x2-seg.x1)*progress;
      const ey = seg.y1 + (seg.y2-seg.y1)*progress;
      const opacity = 0.38 - seg.order*0.028;
      ctx.strokeStyle = `rgba(238,231,213,${Math.max(0.05,opacity)})`;
      ctx.lineWidth = Math.max(0.6, 2.1 - seg.order*0.18);
      ctx.beginPath();
      ctx.moveTo(seg.x1*W, seg.y1*H);
      ctx.lineTo(ex*W, ey*H);
      ctx.stroke();

      if(progress>=1 && seg.depth<=1){
        const pulse = 0.5 + Math.sin(t/900 + seg.order)*0.5;
        ctx.beginPath();
        ctx.arc(seg.x2*W, seg.y2*H, 1.6+pulse*1.1, 0, Math.PI*2);
        ctx.fillStyle = `rgba(238,231,213,${0.15+pulse*0.2})`;
        ctx.fill();
      }
    });
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
</script>

